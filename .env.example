# Copy this file to `.env` in this folder and fill in values.
# `.env` is gitignored — never commit real secrets.
# Do not use `git add -f .env`; if `.env` was ever pushed, rotate all keys and use
# `git filter-repo` or BFG to purge history (see GitHub docs).

# --- Backend (place in `back-end/.env` when running the API) ---
MONGO_URI=mongodb+srv://sekhmimraj199_db_user:REMOVED_SECRET@cluster0.o0mgrot.mongodb.net/myDB?retryWrites=true&w=majority
JWT_SECRET=
AUTH0_ISSUER_BASE_URL=https://YOUR-TENANT.us.auth0.com/
AUTH0_AUDIENCE=

# --- Frontend (Vite) — variables must start with VITE_ ---

# Auth0 SPA (required for login / profile)
VITE_AUTH0_DOMAIN=
VITE_AUTH0_CLIENT_ID=
# Optional: API identifier if you use Auth0 APIs + Express JWT verification
# VITE_AUTH0_AUDIENCE=https://your-api-identifier

# Express API base URL (UserSync, feedback, user profile)
VITE_API_URL=http://localhost:3000

# Web3Forms — form access key from https://web3forms.com
VITE_WEB3FORMS_ACCESS_KEY=

# hCaptcha — site key from https://dashboard.hcaptcha.com
VITE_HCAPTCHA_SITEKEY=

# Google Books API — key from Google Cloud Console (Books API enabled)
VITE_GOOGLE_BOOKS_API_KEY=

# Botpress — full URL to webchat config.js (Project → Webchat → Install)
VITE_BOTPRESS_WEBCHAT_CONFIG_URL=
